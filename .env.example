# Host ports
FRONTEND_PORT=8088
BACKEND_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379

# Host mount directories. Docker Compose creates them automatically if missing.
# Use forward slashes on Windows, for example D:/mealops/mysql.
MEALOPS_MYSQL_DATA_DIR=./docker-data/mysql
MEALOPS_REDIS_DATA_DIR=./docker-data/redis
MEALOPS_UPLOADS_DIR=./docker-data/uploads
MEALOPS_LOGS_DIR=./docker-data/logs

# MySQL. Database name is fixed as reggie by docker-compose.yml and SQL scripts.
MYSQL_ROOT_PASSWORD=mealops-dev-root
MYSQL_USERNAME=root
MYSQL_PASSWORD=mealops-dev-root

# Redis. Leave REDIS_PASSWORD empty to disable Redis auth.
REDIS_DATABASE=0
REDIS_PASSWORD=

# Backend auth
MEALOPS_JWT_SECRET=change-this-secret-before-production
MEALOPS_JWT_TTL_HOURS=2
