#
# 本文件用于统一忽略 MealOps 项目在本地开发、构建、调试过程中产生的非必要文件，
# 避免将依赖目录、构建产物、日志文件、IDE 配置和系统临时文件误提交到仓库。
#

# Java / Spring Boot 构建产物
target/
logs/
uploads/
docker-data/

# Maven 本地缓存目录
.m2/
.m2repo/
.m2repo*/

# Python 本地缓存
__pycache__/
*.pyc

# 前端依赖与构建产物
node_modules/
frontend/node_modules/
dist/
frontend/dist/
dist-ssr/
.node_modules/

# Trae 本地工作目录
.trae/

# IDE 与编辑器配置
.idea/
.vscode/
*.iml

# 环境变量与本地覆写配置
.env
.env.local
.env.*.local
*.local

# 日志与临时文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.pid

# Windows / macOS 系统临时文件
Thumbs.db
.DS_Store

# Maven Wrapper 二进制文件
.mvn/wrapper/maven-wrapper.jar
